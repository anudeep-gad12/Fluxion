# Reasoner Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Defaults to LM Studio at localhost:1234 if not set.
# For production with DeepInfra, uncomment and configure these:

# LLM_BASE_URL=https://api.deepinfra.com/v1/openai
# LLM_API_KEY=your-deepinfra-api-key
# LLM_ENDPOINT=chat_completions

# =============================================================================
# DeepInfra API Key
# =============================================================================
# Required for production deployment with DeepInfra
# Get your key from: https://deepinfra.com/dash/api_keys

DEEPINFRA_API_KEY=

# =============================================================================
# Tool APIs
# =============================================================================
# Web search & extract (Parallel.ai)
# Get your key from: https://parallel.ai

PARALLEL_API_KEY=

# Python sandbox execution (E2B)
# Get your key from: https://e2b.dev

E2B_API_KEY=
