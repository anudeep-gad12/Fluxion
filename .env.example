# Reasoner Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Configure via: ./dev.sh provider [local|deepinfra]
#
# Local (llama-server with gpt-oss):
#   LLM_BASE_URL=http://localhost:8080/v1
#   LLM_ENDPOINT=chat_completions
#   LLM_MODEL=gpt-oss-20b
#
# Cloud (DeepInfra):
#   LLM_BASE_URL=https://api.deepinfra.com/v1/openai
#   LLM_ENDPOINT=chat_completions
#   LLM_MODEL=openai/gpt-oss-120b

# These are set automatically by ./dev.sh provider command
# LLM_BASE_URL=
# LLM_ENDPOINT=
# LLM_MODEL=

# =============================================================================
# DeepInfra API Key (required for cloud)
# =============================================================================
# Get your key from: https://deepinfra.com/dash/api_keys

DEEPINFRA_API_KEY=

# =============================================================================
# Tool APIs
# =============================================================================
# Web search & extract (Parallel.ai)
# Get your key from: https://parallel.ai

PARALLEL_API_KEY=

# =============================================================================
# llama-server Local Setup (gpt-oss with Harmony format)
# =============================================================================
# Start llama-server with gpt-oss model:
#
#   llama-server -m ~/.lmstudio/models/lmstudio-community/gpt-oss-20b-GGUF/gpt-oss-20b-MXFP4.gguf \
#     --jinja --ctx-size 4096 -ub 512 -b 512 --port 8080
#
# Then switch provider:
#   ./dev.sh provider local
#   ./dev.sh restart
#
# Note: gpt-oss models use Harmony format which llama-server supports natively.
# The model outputs reasoning_content (thinking) + content (answer) separately.
