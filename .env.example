# Reasoner Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Configure via: ./dev.sh provider [local|deepinfra]
#
# Local (vLLM):
#   LLM_BASE_URL=http://localhost:8000/v1
#   LLM_ENDPOINT=chat_completions
#   LLM_MODEL=Qwen/Qwen2.5-14B-Instruct
#
# Cloud (DeepInfra):
#   LLM_BASE_URL=https://api.deepinfra.com/v1/openai
#   LLM_ENDPOINT=chat_completions
#   LLM_MODEL=openai/gpt-oss-120b

# These are set automatically by ./dev.sh provider command
# LLM_BASE_URL=
# LLM_ENDPOINT=
# LLM_MODEL=

# =============================================================================
# DeepInfra API Key (required for cloud)
# =============================================================================
# Get your key from: https://deepinfra.com/dash/api_keys

DEEPINFRA_API_KEY=

# =============================================================================
# Tool APIs
# =============================================================================
# Web search & extract (Parallel.ai)
# Get your key from: https://parallel.ai

PARALLEL_API_KEY=

# =============================================================================
# vLLM Local Setup
# =============================================================================
# Start vLLM with tool calling support:
#
#   vllm serve Qwen/Qwen2.5-14B-Instruct \
#     --enable-auto-tool-choice \
#     --tool-call-parser hermes \
#     --port 8000
#
# Then switch provider:
#   ./dev.sh provider local
#   ./dev.sh restart
