# Production Environment Variables for Railway Deployment
# Copy this to Railway dashboard > Variables (DO NOT commit actual values)

# =============================================================================
# Required - LLM Provider
# =============================================================================
# DeepInfra API key for LLM inference
DEEPINFRA_API_KEY=

# =============================================================================
# Required - Python Sandbox (Daytona)
# =============================================================================
# Daytona API key for isolated Python execution
# Supports both DAYTONA_API_KEY and DAYTONA_API (for compatibility)
DAYTONA_API_KEY=
# Set to "daytona" for production, "local" for development
PYTHON_PROVIDER=daytona

# =============================================================================
# Optional - Agent Tools
# =============================================================================
# Parallel.ai API key for web search/extract (optional)
PARALLEL_API_KEY=

# =============================================================================
# Production Settings
# =============================================================================
# Serve frontend from FastAPI (single service deployment)
SERVE_STATIC=true

# Logging configuration
LOG_LEVEL=INFO
LOG_TO_FILE=false

# Database path (use Railway volume mount)
DATABASE_PATH=/data/traces.sqlite

# CORS origins (comma-separated, update with your Railway URL)
CORS_ORIGINS=https://your-app.up.railway.app

# =============================================================================
# Railway-Specific (auto-set by Railway)
# =============================================================================
# PORT - automatically set by Railway
# RAILWAY_ENVIRONMENT - automatically set by Railway
