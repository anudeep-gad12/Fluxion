/* ═══════════════════════════════════════════════
   Reasoner CLI — Claude Code visual style

   Zero chrome. Everything is styled text on a
   dark background. No visible widget boundaries,
   borders, or panels.
   ═══════════════════════════════════════════════ */

Screen {
    background: $background;
    layers: base overlay;
}

/* ── Message List ────────────────────────────── */

#message-list {
    height: 1fr;
    padding: 0;
    scrollbar-size: 0 0;
}

/* ── Input Area ──────────────────────────────── */

#input-container {
    height: auto;
    max-height: 14;
    padding: 0;
}

#prompt-row {
    height: auto;
    min-height: 1;
    max-height: 8;
    padding: 0;
}

#input-prompt {
    width: 4;
    height: 1;
    padding: 0 0 0 2;
    color: $text-muted;
    background: $background;
}

#input-area {
    width: 1fr;
    height: auto;
    min-height: 1;
    max-height: 8;
    border: none;
    background: $background;
    padding: 0;
    margin: 0;
}

#input-area:focus {
    border: none;
}

#input-area.approval-mode {
    border: round $warning;
    color: $text;
    max-height: 16;
    margin: 0 1;
    padding: 0 1;
}

#input-area.approval-mode:focus {
    border: round $warning;
}

/* ── Status Bar ──────────────────────────────── */

StatusBar {
    height: auto;
    min-height: 1;
    max-height: 3;
    background: $background;
    padding: 0 2;
    color: $text-disabled;
}

StatusBar .status-item {
    width: auto;
    height: 1;
}

StatusBar .status-separator {
    color: $text-disabled;
}

StatusBar .status-provider {
    color: $text-disabled;
}

StatusBar .status-activity {
    color: $text-muted;
    text-style: italic;
}

StatusBar .status-spacer {
    width: 1fr;
}

StatusBar .status-context {
    color: $text-disabled;
}

StatusBar .status-hints {
    color: $text-disabled;
}

/* ── Welcome ─────────────────────────────────── */

#welcome {
    margin: 1 0 0 0;
    padding: 0 2;
    height: auto;
    color: $text-muted;
}

/* ── Message Bubbles ─────────────────────────── */

MessageBubble {
    height: auto;
    margin: 0;
    padding: 0 2;
}

MessageBubble.user {
    margin-top: 1;
    padding: 0 0 0 1;
    background: #1a1a2e;
    border-left: outer #7c3aed;
}

MessageBubble.assistant {
    padding: 0 2;
}

.user-message {
    color: $text;
    padding: 0 1;
}

MessageBubble.system {
    padding: 0 2;
    margin: 0;
}

.system-message {
    color: $text-disabled;
}

/* ── Tool Call Panels ────────────────────────── */

ToolCallPanel {
    margin: 0;
    padding: 0 2;
    height: auto;
}

MessageBubble ToolCallPanel {
    margin: 0;
    padding: 0;
}

ToolCallPanel .tool-header {
    height: 1;
}

ToolCallPanel .tool-details {
    display: none;
    color: $text-muted;
}

ToolCallPanel.expanded .tool-details {
    display: block;
    height: auto;
    padding: 0 0 0 2;
}

ToolCallPanel .tool-result {
    padding: 0;
}

ToolCallPanel .tool-error {
    padding: 0;
}

ToolCallPanel .tool-approval {
    padding: 0;
}

/* ── Thinking Panel ──────────────────────────── */

ThinkingPanel {
    color: #a78bfa;
    height: 1;
    margin: 0;
    padding: 0 2;
}

ThinkingPanel.expanded {
    height: auto;
}

MessageBubble ThinkingPanel {
    margin: 0;
    padding: 0;
}

MessageBubble ThinkingPanel.expanded {
    height: auto;
}

/* ── Streaming Markdown ──────────────────────── */

StreamingMarkdown {
    margin: 0;
    padding: 0;
}

/* ═══════════════════════════════════════════════
   Markdown component overrides

   Textual's Markdown widget has heavy defaults:
   - margin: 0 4 1 4  (4-char horizontal indent!)
   - H1/H2: colored backgrounds, borders, center-aligned
   - Code fences: bordered boxes

   We strip ALL of this for a clean terminal look.
   ═══════════════════════════════════════════════ */

Markdown {
    margin: 0;
    padding: 0;
}

MarkdownH1 {
    background: transparent;
    border: none;
    content-align: left top;
    text-align: left;
    text-style: bold;
    color: $text;
    padding: 0;
    margin: 1 0 0 0;
}

MarkdownH2 {
    background: transparent;
    border: none;
    text-align: left;
    text-style: bold underline;
    color: $text;
    padding: 0;
    margin: 1 0 0 0;
}

MarkdownH3 {
    text-style: bold;
    color: $text;
    padding: 0;
    margin: 1 0 0 0;
}

MarkdownH4 {
    text-style: bold;
    color: $text;
    padding: 0;
    margin: 0;
}

MarkdownH5 {
    text-style: bold;
    color: $text;
    padding: 0;
    margin: 0;
}

MarkdownH6 {
    text-style: bold;
    color: $text-muted;
    padding: 0;
    margin: 0;
}

MarkdownFence {
    margin: 0 0 1 0;
    padding: 0 1;
    background: $surface;
    border: none;
    max-height: 50;
    overflow: auto;
}

MarkdownBlockQuote {
    margin: 0 0 1 0;
    padding: 0 0 0 2;
    border-left: outer $primary;
    color: $text-muted;
}

MarkdownBulletList {
    margin: 0;
    padding: 0 0 0 2;
}

MarkdownOrderedList {
    margin: 0;
    padding: 0 0 0 2;
}

MarkdownTable {
    margin: 0 0 1 0;
    padding: 0;
}

MarkdownHorizontalRule {
    margin: 1 0;
    color: $surface;
}
