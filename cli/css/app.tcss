/* Reasoner CLI — Clean Terminal UI (Claude Code style) */

Screen {
    background: $background;
    layers: base overlay;
}

/* ── Header ─────────────────────────────────────────── */

Header {
    dock: top;
    height: 1;
    background: $surface;
    color: $text;
}

/* ── Message List (main content area) ───────────────── */

#message-list {
    height: 1fr;
    padding: 1 0;
    scrollbar-size: 1 1;
    scrollbar-color: $surface-lighten-2;
    scrollbar-color-hover: $primary;
    scrollbar-color-active: $primary;
}

/* ── Input + Status Area ───────────────────────────── */

#input-container {
    height: auto;
    max-height: 12;
    margin: 0 2;
    padding: 0;
}

#input-area {
    height: auto;
    min-height: 3;
    max-height: 8;
    border: round $surface-lighten-2;
    background: $surface;
    padding: 0 1;
}

#input-area:focus {
    border: round $primary-lighten-2;
}

#input-area.approval-mode {
    border: round $warning;
    color: $text;
    max-height: 16;
}

#input-area.approval-mode:focus {
    border: round $warning;
}

/* ── Status Bar ─────────────────────────────────────── */

StatusBar {
    height: 1;
    background: $background;
    padding: 0 1;
    color: $text-muted;
}

StatusBar .status-item {
    width: auto;
    height: 1;
}

StatusBar .status-mode {
    color: $primary;
    text-style: bold;
}

StatusBar .status-separator {
    color: $text-disabled;
}

StatusBar .status-provider {
    color: $text-muted;
}

StatusBar .status-activity {
    color: $text-muted;
    text-style: italic;
}

StatusBar .status-spacer {
    width: 1fr;
}

StatusBar .status-context {
    color: $text-muted;
}

StatusBar .status-connection {
    color: $success;
}

StatusBar .status-disconnected {
    color: $error;
}

/* ── Welcome Message ────────────────────────────────── */

#welcome {
    margin: 2 4;
    padding: 1 2;
    height: auto;
    color: $text-muted;
}

/* ── Message Bubbles ────────────────────────────────── */

MessageBubble {
    height: auto;
    margin: 0 2 1 2;
    padding: 0;
}

MessageBubble.user {
    margin-top: 1;
}

MessageBubble.assistant {
    padding: 0;
}

.user-message {
    color: $text;
}

MessageBubble.system {
    padding: 0;
    margin: 0 2 0 2;
}

.system-message {
    color: $text-muted;
}

/* ── Tool Call Panels ───────────────────────────────── */

ToolCallPanel {
    margin: 0 2 0 2;
    padding: 0;
    height: auto;
}

MessageBubble ToolCallPanel {
    margin: 0;
}

ToolCallPanel .tool-header {
    height: 1;
}

ToolCallPanel .tool-details {
    display: none;
    color: $text-muted;
}

ToolCallPanel.expanded .tool-details {
    display: block;
    height: auto;
    padding: 0 0 0 2;
}

ToolCallPanel .tool-result {
    padding: 0;
}

ToolCallPanel .tool-error {
    padding: 0;
}

ToolCallPanel .tool-approval {
    padding: 0;
}

/* ── Thinking Panel ────────────────────────────────── */

ThinkingPanel {
    color: $text-disabled;
    height: 1;
    margin: 0 2;
}

ThinkingPanel.expanded {
    height: auto;
}

MessageBubble ThinkingPanel {
    margin: 0;
}

MessageBubble ThinkingPanel.expanded {
    height: auto;
}

/* ── Streaming Markdown ─────────────────────────────── */

StreamingMarkdown {
    margin: 0 2 1 2;
    padding: 0;
}
