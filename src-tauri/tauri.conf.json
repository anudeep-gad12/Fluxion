{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fluxion",
  "version": "0.2.2",
  "identifier": "io.fluxion.local",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://127.0.0.1:9000",
    "beforeDevCommand": "bash scripts/tauri-before-dev.sh",
    "beforeBuildCommand": "bash scripts/tauri-before-build.sh"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Fluxion",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/fluxion-server"],
    "resources": ["../ui/dist"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "frameworks": ["Frameworks/Sparkle.framework"],
      "minimumSystemVersion": "13.0",
      "infoPlist": "Info.extend.plist"
    },
    "createUpdaterArtifacts": false
  }
}
