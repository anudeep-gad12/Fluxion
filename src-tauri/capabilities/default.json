{
  "identifier": "default",
  "description": "Default Fluxion desktop capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-create",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-center",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "fluxion-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-spawn"
  ]
}
